<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ─── CAMERA PREVIEW ─── -->
    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"/>

    <!-- ─── DARK VIGNETTE OVERLAY ─── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/scanner_vignette"/>

    <!-- ─── TOP BAR ─── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#CC0D1117"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🌿 AGROTEC GUINEA"
                android:textColor="@color/accent_green"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"/>

            <ImageButton
                android:id="@+id/btnVoice"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/btn_voice_bg"
                android:src="@android:drawable/ic_lock_silent_mode_off"
                android:tint="@color/white"
                android:contentDescription="Asistente de voz"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvWeather"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="🌤 Cargando clima..."
            android:textColor="@color/text_secondary"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- ─── PROFESSIONAL SCANNER FRAME ─── -->
    <FrameLayout
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="center">

        <!-- Semi-transparent interior -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#1A2EA043"/>

        <!-- Corner: Top-Left -->
        <View android:layout_width="40dp" android:layout_height="4dp" android:layout_gravity="top|start" android:background="@color/accent_green"/>
        <View android:layout_width="4dp" android:layout_height="40dp" android:layout_gravity="top|start" android:background="@color/accent_green"/>
        <!-- Corner: Top-Right -->
        <View android:layout_width="40dp" android:layout_height="4dp" android:layout_gravity="top|end" android:background="@color/accent_green"/>
        <View android:layout_width="4dp" android:layout_height="40dp" android:layout_gravity="top|end" android:background="@color/accent_green"/>
        <!-- Corner: Bottom-Left -->
        <View android:layout_width="40dp" android:layout_height="4dp" android:layout_gravity="bottom|start" android:background="@color/accent_green"/>
        <View android:layout_width="4dp" android:layout_height="40dp" android:layout_gravity="bottom|start" android:background="@color/accent_green"/>
        <!-- Corner: Bottom-Right -->
        <View android:layout_width="40dp" android:layout_height="4dp" android:layout_gravity="bottom|end" android:background="@color/accent_green"/>
        <View android:layout_width="4dp" android:layout_height="40dp" android:layout_gravity="bottom|end" android:background="@color/accent_green"/>

        <!-- Animated scan line -->
        <View
            android:id="@+id/scanLine"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_gravity="center_vertical"
            android:background="@drawable/scan_line_gradient"/>
    </FrameLayout>

    <!-- ─── SCAN HINT TEXT ─── -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="360dp"
        android:background="#99000000"
        android:padding="8dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="📷 Apunta al cultivo y pulsa ANALIZAR"
        android:textColor="@color/white"
        android:textSize="13sp"/>

    <!-- ─── CAPTURE INDICATOR PILL ─── -->
    <TextView
        android:id="@+id/captureIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="305dp"
        android:background="@drawable/pill_green_bg"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:text="● CÁMARA ACTIVA"
        android:textColor="@color/white"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:visibility="gone"/>

    <!-- ─── PROGRESS BAR ─── -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="185dp"
        android:indeterminate="true"
        android:indeterminateTint="@color/accent_green"
        android:visibility="gone"/>

    <!-- ─── FAB SCAN BUTTON ─── -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/scanFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="200dp"
        android:backgroundTint="@color/accent_green"
        android:text="  ANALIZAR CON GROQ LPU"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="15sp"
        app:cornerRadius="28dp"
        app:elevation="8dp"
        app:icon="@android:drawable/ic_menu_camera"
        app:iconTint="@color/white"/>

    <!-- ─── RESULT CARD (bottom sheet style) ─── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/resultCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="12dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="28dp"
        app:cardElevation="16dp"
        app:strokeColor="@color/accent_green"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Drag handle -->
            <View
                android:layout_width="36dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp"
                android:background="@color/border_color"/>

            <!-- Status chip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tvCrop"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"/>
                <TextView
                    android:id="@+id/severityBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/badge_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="● GRAVEDAD"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvPest"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Confianza del análisis"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"/>
                <TextView
                    android:id="@+id/tvConfidence"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent_green"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="14dp"
                android:background="@color/border_color"/>

            <!-- Treatment Section -->
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌿 " android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TRATAMIENTO LOCAL" android:textColor="@color/accent_green" android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.1"/>
            </LinearLayout>
            <TextView
                android:id="@+id/tvTreatment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"/>

            <!-- AI Advice Section -->
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="14dp" android:layout_marginBottom="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🤖 " android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CONSEJO GEMINI AI" android:textColor="@color/accent_blue" android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.1"/>
            </LinearLayout>
            <TextView
                android:id="@+id/tvAdvice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:lineSpacingExtra="3dp"/>

            <!-- Voice button -->
            <Button
                android:id="@+id/btnReadAloud"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="#1A2EA043"
                android:text="🔊  ESCUCHAR ANÁLISIS"
                android:textColor="@color/accent_green"
                android:textStyle="bold"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:strokeColor="@color/accent_green"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>

            <TextView
                android:id="@+id/tvSeverity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/text_muted"
                android:textSize="12sp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
